{
  "version": 2,
  
  // ==================== BUILD CONFIG ====================
  "builds": [
    {
      "src": "api/server.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "maxDuration": 60
      }
    }
  ],
  
  // ==================== ROUTING ====================
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.py"
    },
    {
      "src": "/docs",
      "dest": "api/server.py"
    },
    {
      "src": "/redoc",
      "dest": "api/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/server.py"
    }
  ],
  
  // ==================== ENVIRONMENT ====================
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHON_VERSION": "3.11"
  },
  
  // ==================== REGIONS ====================
  "regions": ["sin1"],
  
  // ==================== FUNCTION CONFIG ====================
  "functions": {
    "api/server.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  
  // ==================== OUTPUT CONFIG ====================
  "outputDirectory": "api",
  
  // ==================== INSTALL COMMAND ====================
  "installCommand": "pip install -r requirements.vercel.txt"
}
