{
  "framework": null,
  "buildCommand": "pip install -r requirements.vercel.txt",
  "outputDirectory": "api",
  "installCommand": "pip install -r requirements.vercel.txt",
  "devCommand": "uvicorn api.server:app --reload",
  "regions": ["sin1"],
  
  "builds": [
    {
      "src": "api/server.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "maxDuration": 60,
        "memory": 1024
      }
    }
  ],
  
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.py"
    },
    {
      "src": "/docs",
      "dest": "api/server.py"
    },
    {
      "src": "/redoc",
      "dest": "api/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/server.py"
    }
  ],
  
  "env": {
    "PYTHONUNBUFFERED": "1",
    "VERCEL": "1"
  }
}
